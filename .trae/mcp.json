{
    "mcpServers": {
        "laravel-boost": {
            "command": "php82",
            "args": [
                "artisan",
                "boost:mcp"
            ],
            "cwd": "${workspaceFolder}"
        },
        "Skeleton V12 - API 文档": {
            "command": "npx",
            "args": [
                "-y",
                "apifox-mcp-server@latest",
                "--site-id=5455708"
            ]
        },
        "Skeleton V12 Admin 文档": {
            "command": "npx",
            "args": [
                "-y",
                "apifox-mcp-server@latest",
                "--site-id=5510593"
            ]
        }
    }
}